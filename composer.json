{
    "name": "christo/plentific-api",
    "description": "API client for Plentific user interaction challenge",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "autoload": {
        "psr-4": {
            "Christo\\PlentificApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Christo\\PlentificApi\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Christo Papadopoulo"
        }
    ],
    "require": {
        "php": "^8.4",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "nyholm/psr7": "^1.8",
        "php-http/mock-client": "^1.6"
    },
   "scripts": {
      "test": "phpunit",
      "stan": "phpstan analyse"
  },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
